# PropManager v2 — Environment Variables
# Copy this to .env for local development
# In production, set these in Render's Environment settings

# ============================================================
# REQUIRED IN PRODUCTION
# ============================================================

# Database connection (provided by Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT signing secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string-in-production

# Field-level encryption key for PII (guest names, emails, phone, ID numbers)
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=generate-a-fernet-key-here

# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=https://your-frontend.onrender.com,https://your-custom-domain.com

# Set to "production" to enable SSL enforcement, hide /docs, sanitize error messages
ENVIRONMENT=production

# ============================================================
# OPTIONAL
# ============================================================

# Python version (for Render)
PYTHON_VERSION=3.11.9
